# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# CLAUDE API (Anthropic)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-key

# ============================================================
# TELEGRAM BOT
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token
# Telegram chat ID руководителя (получить через @userinfobot)
MANAGER_TELEGRAM_CHAT_ID=123456789
# Список ID менеджеров через запятую
MANAGER_TELEGRAM_IDS=123456789,987654321

# ============================================================
# RESEND (email поставщикам)
# ============================================================
RESEND_API_KEY=re_your-key
FROM_EMAIL=agent@yourdomain.com

# ============================================================
# VERCEL CRON (секрет для защиты cron endpoints)
# ============================================================
CRON_SECRET=your-random-secret-string
